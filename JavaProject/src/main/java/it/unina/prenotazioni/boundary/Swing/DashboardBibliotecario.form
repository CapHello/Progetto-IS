<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="it.unina.prenotazioni.boundary.Swing.DashboardBibliotecario">
  <grid id="27dc6" binding="dashboardPane" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="1000" height="760"/>
    </constraints>
    <properties>
      <background color="-5192482"/>
    </properties>
    <border type="none"/>
    <children>

      <grid id="1f594" binding="header" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="10" left="15" bottom="10" right="15"/>
