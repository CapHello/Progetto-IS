<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="prenotazioniPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>it.unina.prenotazioni.entity.Utente</class>
        <class>it.unina.prenotazioni.entity.Studente</class>
        <class>it.unina.prenotazioni.entity.Bibliotecario</class>
        <class>it.unina.prenotazioni.entity.SalaStudio</class>
        <class>it.unina.prenotazioni.entity.Area</class>
        <class>it.unina.prenotazioni.entity.Postazione</class>
        <class>it.unina.prenotazioni.entity.FasciaOraria</class>
        <class>it.unina.prenotazioni.entity.Prenotazione</class>

        <properties>
            <!-- Connessione a MySQL -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/prenotazionidb_test?serverTimezone=UTC&amp;createDatabaseIfNotExist=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="admin"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <!-- Configurazione Hibernate per MySQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
