<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="it.unina.prenotazioni.boundary.Swing.PrenotazioneConfermata">
  <grid id="27dc6" binding="confermataPane" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="960" height="700"/>
    </constraints>
    <properties>
      <background color="-5192482"/>
    </properties>
    <border type="none"/>
    <children>

      <!-- HEADER (row=0) -->
      <grid id="1f594" binding="header" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="10" left="15" bottom="10" right="15"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-8621082"/>
          <opaque value="true"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="8922e" class="javax.swing.JLabel" binding="lblTitolo">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="SansSerif" size="20" style="1"/>
              <foreground color="-1"/>
              <text value="  Dashboard Studente"/>
            </properties>
          </component>
          <hspacer id="22799">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>
          <component id="f585" class="javax.swing.JButton" binding="btnLogout">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Logout"/>
            </properties>
          </component>
        </children>
      </grid>

      <!-- STEPS (row=1) -->
      <grid id="a1b2c" binding="pannelloSteps" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="12" left="20" bottom="12" right="20"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-5192482"/>
          <opaque value="true"/>
        </properties>
        <border type="none"/>
        <children>
          <component id="b2c3d" class="javax.swing.JLabel" binding="lblSteps">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <foreground color="-6710887"/>
              <text value="1 Data &amp; Sala  ──  2 Fascia Oraria  ──  3 Area  ──  4 Postazione  ──  5 Conferma"/>
            </properties>
          </component>
        </children>
      </grid>

      <!-- CONTENUTO (row=2): card successo centrata -->
      <grid id="c3d4e" binding="pannelloContenuto" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="15" left="30" bottom="20" right="30"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-5192482"/>
          <opaque value="true"/>
        </properties>
        <border type="none"/>
        <children>

          <hspacer id="b7c8d">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>

          <grid id="d4e5f" binding="cardConfermata" layout-manager="GridLayoutManager" row-count="5" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="18">
            <margin top="20" left="20" bottom="20" right="20"/>
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="1" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="520" height="-1"/>
              </grid>
            </constraints>
            <properties>
              <background color="-1"/>
              <opaque value="true"/>
            </properties>
            <border type="none"/>
            <children>
              <!-- Icona successo: cerchio con spunta disegnato dal costruttore Java -->
              <grid id="e5f6a" binding="pannelloIcona" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false">
                    <preferred-size width="100" height="100"/>
                  </grid>
                </constraints>
                <properties>
                  <background color="-1"/>
                  <opaque value="true"/>
                </properties>
                <border type="none"/>
                <children/>
              </grid>
              <component id="a0b1c" class="javax.swing.JLabel" binding="lblTitolone">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <font name="SansSerif" size="26" style="1"/>
                  <horizontalAlignment value="0"/>
                  <text value="Prenotazione Confermata"/>
                </properties>
              </component>
              <component id="b1c2d" class="javax.swing.JLabel" binding="lblMessaggio">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <foreground color="-6710887"/>
                  <horizontalAlignment value="0"/>
                  <text value="La prenotazione è stata registrata."/>
                </properties>
              </component>
              <grid id="c2d3e" binding="pannelloBox" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="6">
                <margin top="14" left="14" bottom="14" right="14"/>
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <background color="-460036"/>
                  <opaque value="true"/>
                </properties>
                <border type="none"/>
                <children>
                  <component id="d6f7a" class="javax.swing.JLabel" binding="lblBoxRiga1">
                    <constraints>
                      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <font name="SansSerif" size="14" style="1"/>
                      <horizontalAlignment value="0"/>
                      <text value="sala · area · postazione"/>
                    </properties>
                  </component>
                  <component id="e7a8b" class="javax.swing.JLabel" binding="lblBoxRiga2">
                    <constraints>
                      <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <foreground color="-6710887"/>
                      <horizontalAlignment value="0"/>
                      <text value="data | fascia"/>
                    </properties>
                  </component>
                </children>
              </grid>
              <component id="f8b9c" class="javax.swing.JButton" binding="btnDashboard">
                <constraints>
                  <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <background color="-8621082"/>
                  <foreground color="-1"/>
                  <text value="Torna alla dashboard"/>
                </properties>
              </component>
            </children>
          </grid>

          <hspacer id="c8d9e">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
          </hspacer>

        </children>
      </grid>

    </children>
  </grid>
</form>
